{% comment %}
  Restock Raven v1 widget snippet (duplicate theme only)
  - Kill switch: theme setting enable_restock_raven
  - Only renders when selected variant is unavailable
  - Posts to backend /api/restock/subscribe
{% endcomment %}

{% if settings.enable_restock_raven %}
  <style>
    #restock-raven {
      --rr-bg: #ffffff;
      --rr-text: #222222;
      --rr-accent: #f2a95d;
      --rr-soft: #b9c4cf;
      --rr-border: #ddd6cf;
      --rr-muted: #5c6772;
      --rr-font-body: var(--font-body-family, var(--font-body-family-fallback, inherit));
      --rr-font-heading: var(--font-heading-family, var(--rr-font-body));
      display: none;
      margin-top: 14px;
      padding: 16px;
      border: 1px solid var(--rr-border);
      border-radius: 14px;
      background: linear-gradient(180deg, #fffdf9 0%, #ffffff 100%);
      color: var(--rr-text);
      font-family: var(--rr-font-body);
      box-shadow: 0 10px 25px rgba(34, 34, 34, 0.04);
    }

    #restock-raven .rr-title {
      margin: 0 0 6px;
      font-size: 17px;
      line-height: 1.3;
      font-weight: 700;
      font-family: var(--rr-font-heading);
      letter-spacing: 0.01em;
    }

    #restock-raven .rr-copy {
      margin: 0 0 12px;
      font-size: 13px;
      line-height: 1.45;
      color: var(--rr-muted);
    }

    #restock-raven .rr-grid {
      display: grid;
      gap: 10px;
      grid-template-columns: 1fr;
    }

    #restock-raven .rr-field {
      display: grid;
      gap: 6px;
    }

    #restock-raven .rr-field-label {
      font-size: 12px;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: var(--rr-muted);
      font-weight: 700;
    }

    #restock-raven input[type="email"] {
      width: 100%;
      min-height: 42px;
      border: 1px solid var(--rr-border);
      border-radius: 10px;
      padding: 10px 12px;
      background: #fff;
      color: var(--rr-text);
      font-family: var(--rr-font-body);
      font-size: 14px;
    }

    #restock-raven label {
      display: flex;
      gap: 8px;
      align-items: flex-start;
      font-size: 13px;
      line-height: 1.35;
      color: #3d3d3d;
      font-family: var(--rr-font-body);
    }

    #restock-raven input[type="checkbox"] {
      margin-top: 2px;
      accent-color: var(--rr-accent);
    }

    #restock-raven button[type="submit"] {
      min-height: 42px;
      border: 1px solid #e09a57;
      border-radius: 10px;
      background: var(--rr-accent);
      color: #1a1a1a;
      font-weight: 700;
      letter-spacing: 0.02em;
      font-family: var(--rr-font-heading);
      font-size: 14px;
      cursor: pointer;
      transition: transform 120ms ease, box-shadow 120ms ease, background-color 120ms ease;
      box-shadow: 0 2px 0 rgba(0, 0, 0, 0.1);
    }

    #restock-raven button[disabled] {
      opacity: 0.65;
      cursor: wait;
      transform: none;
      box-shadow: none;
    }

    #restock-raven button[type="submit"]:hover {
      transform: translateY(-1px);
      background: #ffb676;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    #restock-raven button[type="submit"]:focus-visible,
    #restock-raven input:focus-visible {
      outline: 2px solid var(--rr-soft);
      outline-offset: 2px;
    }

    #restock-raven-result {
      margin: 6px 0 0;
      font-size: 12px;
      color: #4a5764;
      font-family: var(--rr-font-body);
    }

    #restock-raven-result[data-state="success"] {
      color: #22603a;
    }

    #restock-raven-result[data-state="error"] {
      color: #9f2f2f;
    }
  </style>
  <div id="restock-raven" data-product-id="{{ product.id }}">
    <p class="rr-title">Get a restock alert</p>
    <p class="rr-copy">Leave your email and we'll let you know when this item is back.</p>
    <form id="restock-raven-form" class="rr-grid">
      <div class="rr-field">
        <label class="rr-field-label" for="restock-raven-email">Email</label>
        <input id="restock-raven-email" type="email" name="email" placeholder="you@example.com" autocomplete="email" />
      </div>
      <label>
        <input type="checkbox" name="marketingOptIn" value="true" />
        Email me about new arrivals and future restocks too.
      </label>
      <button type="submit">Email me when it's back</button>
      <p id="restock-raven-result" style="font-size: 12px;"></p>
    </form>
  </div>

  <script>
    (function () {
      var root = document.getElementById('restock-raven');
      if (!root || !window.Shopify || !window.ShopifyAnalytics) return;

      function getSelectedVariant() {
        if (window.ShopifyAnalytics && window.ShopifyAnalytics.meta && window.ShopifyAnalytics.meta.selectedVariantId) {
          var id = String(window.ShopifyAnalytics.meta.selectedVariantId);
          return (window.meta && window.meta.product && window.meta.product.variants || []).find(function (v) {
            return String(v.id) === id;
          });
        }
        return null;
      }

      function updateVisibility() {
        var v = getSelectedVariant();
        if (!v) return;
        root.dataset.variantId = String(v.id);
        root.style.display = v.available ? 'none' : 'block';
      }

      document.addEventListener('variant:change', updateVisibility);
      document.addEventListener('change', function (e) {
        if (e.target && e.target.name === 'id') updateVisibility();
      });
      updateVisibility();

      var form = document.getElementById('restock-raven-form');
      var result = document.getElementById('restock-raven-result');
      var submitButton = form.querySelector('button[type="submit"]');

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        result.textContent = '';
        result.dataset.state = '';
        submitButton.disabled = true;
        var fd = new FormData(form);
        var payload = {
          email: fd.get('email') || null,
          marketingOptIn: fd.get('marketingOptIn') === 'true',
          productId: root.dataset.productId,
          variantId: root.dataset.variantId
        };

        var endpoint = window.restockRavenEndpoint || 'https://restock-raven.vercel.app/api/restock/subscribe';
        try {
          var res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(payload)
          });

          if (res.ok) {
            result.dataset.state = 'success';
            result.textContent = "Thanks. We'll email you when it's back.";
            form.reset();
          } else {
            var body = await res.json().catch(function () { return {}; });
            result.dataset.state = 'error';
            result.textContent = body.error || 'Could not subscribe.';
          }
        } catch (error) {
          result.dataset.state = 'error';
          result.textContent = 'Could not subscribe right now. Please try again.';
        } finally {
          submitButton.disabled = false;
        }
      });
    })();
  </script>
{% endif %}
