# App
APP_BASE_URL=https://restock-raven.vercel.app
CRON_JOB_SECRET=change-me
HEALTHCHECK_SECRET=change-me
RESTOCK_TRIGGER_MODE=threshold
RESTOCK_MIN_QTY_FROM_ZERO=11

# Internal Admin Basic Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Neon (via Vercel Marketplace integration)
DATABASE_URL=postgresql://...

# Shopify (single store only, no OAuth)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Option A (legacy): static admin token
SHOPIFY_ADMIN_TOKEN=
# Option B (Dev Dashboard): client credentials token exchange
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Webhook HMAC secret (use app secret from Dev Dashboard)
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_LOCATION_ID=123456789

# Email (Resend)
RESEND_API_KEY=re_xxx
RESEND_FROM=alerts@yourdomain.com

# SMS (Twilio) - optional for email-only mode
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+15551234567
